name: Deploy to Server

on:
  push:
    branches:
      - main

jobs:
  deploy:
    name: Deploy {{AGENT_NAME}} Config
    runs-on: ubuntu-latest
    timeout-minutes: 10

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Deploy via SSH
        uses: appleboy/ssh-action@v1.0.3
        env:
          GH_TOKEN: ${{ secrets.GH_TOKEN }}
        with:
          host: ${{ secrets.SERVER_HOST }}
          username: ${{ secrets.SERVER_USER }}
          key: ${{ secrets.SERVER_SSH_KEY }}
          port: ${{ secrets.SERVER_PORT }}
          envs: GH_TOKEN
          script: |
            set -e
            CONFIG_DIR="/opt/{{AGENT_NAME}}-config"

            echo "=== [1/4] Syncing config ==="
            if [ -d "$CONFIG_DIR/.git" ]; then
              cd "$CONFIG_DIR" && git pull origin main
            else
              sudo mkdir -p "$CONFIG_DIR"
              sudo chown "$USER:$USER" "$CONFIG_DIR"
              git clone "https://${GH_TOKEN}@github.com/{{GH_ORG}}/{{AGENT_NAME}}-config.git" "$CONFIG_DIR"
            fi
            cd "$CONFIG_DIR"

            echo "=== [2/4] Pulling latest Hermes image ==="
            docker compose pull

            echo "=== [3/4] Restarting container ==="
            docker compose up -d --force-recreate

            echo "=== [4/4] Health check ==="
            sleep 10
            docker compose ps
            docker compose logs --tail=20

            echo "Deploy complete"
