name: Deploy to Server

on:
  push:
    branches:
      - main
    paths-ignore:
      - 'memories/**'

jobs:
  deploy:
    name: Deploy {{AGENT_NAME}} Config
    runs-on: ubuntu-latest
    timeout-minutes: 10

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Deploy via SSH
        uses: appleboy/ssh-action@v1.0.3
        env:
          GH_TOKEN: ${{ secrets.GH_TOKEN }}
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
          # ###BEGIN_SLACK###
          SLACK_BOT_TOKEN: ${{ secrets.SLACK_BOT_TOKEN }}
          SLACK_APP_TOKEN: ${{ secrets.SLACK_APP_TOKEN }}
          SLACK_ALLOWED_USERS: ${{ secrets.SLACK_ALLOWED_USERS }}
          # ###END_SLACK###
          # ###BEGIN_DISCORD###
          DISCORD_BOT_TOKEN: ${{ secrets.DISCORD_BOT_TOKEN }}
          DISCORD_GUILD_ID: ${{ secrets.DISCORD_GUILD_ID }}
          # ###END_DISCORD###
          # ###BEGIN_TELEGRAM###
          TELEGRAM_BOT_TOKEN: ${{ secrets.TELEGRAM_BOT_TOKEN }}
          TELEGRAM_ALLOWED_USERS: ${{ secrets.TELEGRAM_ALLOWED_USERS }}
          # ###END_TELEGRAM###
          # ###BEGIN_GITHUB_WEBHOOK###
          WEBHOOK_SECRET: ${{ secrets.WEBHOOK_SECRET }}
          # ###END_GITHUB_WEBHOOK###
        with:
          host: ${{ secrets.SERVER_HOST }}
          username: ${{ secrets.SERVER_USER }}
          key: ${{ secrets.SERVER_SSH_KEY }}
          port: ${{ secrets.SERVER_PORT }}
          envs: GH_TOKEN,ANTHROPIC_API_KEY,SLACK_BOT_TOKEN,SLACK_APP_TOKEN,SLACK_ALLOWED_USERS,DISCORD_BOT_TOKEN,DISCORD_GUILD_ID,TELEGRAM_BOT_TOKEN,TELEGRAM_ALLOWED_USERS,WEBHOOK_SECRET
          script: |
            set -e
            CONFIG_DIR="/opt/{{AGENT_NAME}}-config"
            ENV_FILE="$CONFIG_DIR/.env"

            echo "=== [1/5] Syncing config ==="
            if [ -d "$CONFIG_DIR/.git" ]; then
              cd "$CONFIG_DIR" && git pull origin main
            else
              sudo mkdir -p "$CONFIG_DIR"
              sudo chown "$USER:$USER" "$CONFIG_DIR"
              git clone "https://${GH_TOKEN}@github.com/{{GH_ORG}}/{{AGENT_NAME}}-config.git" "$CONFIG_DIR"
            fi
            cd "$CONFIG_DIR"

            echo "=== [2/5] Writing .env from secrets ==="
            {
              printf '# {{AGENT_NAME}} — generated by GitHub Actions\n'
              printf 'ANTHROPIC_API_KEY=%s\n' "$ANTHROPIC_API_KEY"
              printf 'GH_TOKEN=%s\n' "$GH_TOKEN"
              # ###BEGIN_SLACK###
              printf 'SLACK_BOT_TOKEN=%s\n' "$SLACK_BOT_TOKEN"
              printf 'SLACK_APP_TOKEN=%s\n' "$SLACK_APP_TOKEN"
              printf 'SLACK_ALLOWED_USERS=%s\n' "$SLACK_ALLOWED_USERS"
              # ###END_SLACK###
              # ###BEGIN_DISCORD###
              printf 'DISCORD_BOT_TOKEN=%s\n' "$DISCORD_BOT_TOKEN"
              printf 'DISCORD_GUILD_ID=%s\n' "$DISCORD_GUILD_ID"
              # ###END_DISCORD###
              # ###BEGIN_TELEGRAM###
              printf 'TELEGRAM_BOT_TOKEN=%s\n' "$TELEGRAM_BOT_TOKEN"
              printf 'TELEGRAM_ALLOWED_USERS=%s\n' "$TELEGRAM_ALLOWED_USERS"
              # ###END_TELEGRAM###
              # ###BEGIN_GITHUB_WEBHOOK###
              printf 'GITHUB_WEBHOOK_SECRET=%s\n' "$WEBHOOK_SECRET"
              # ###END_GITHUB_WEBHOOK###
            } > "$ENV_FILE"
            chmod 644 "$ENV_FILE"
            sudo chown 10000:10000 "$ENV_FILE" 2>/dev/null || true

            echo "=== [3/5] Pulling latest Hermes image ==="
            docker compose pull

            echo "=== [4/5] Restarting container ==="
            docker compose up -d --force-recreate

            echo "=== [5/5] Health check ==="
            sleep 10
            docker compose ps
            docker compose logs --tail=20

            echo "Deploy complete"
